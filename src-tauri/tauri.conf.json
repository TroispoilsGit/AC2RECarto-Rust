{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AC2RECarto",
  "version": "0.1.0",
  "identifier": "com.ac2re.carto",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Map : Asheron's Call 2",
        "width": 800,
        "height": 600,
        "resizable": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "icon": []
  }
}
